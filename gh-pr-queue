#!/usr/bin/env bash
set -euo pipefail

CONFIG_PATH="${GH_PR_QUEUE_CONFIG:-$HOME/.config/gh-pr-queue/config}"
CUTOFF_DAYS=14
ORGS=
TEAMS_INCLUDE=
TEAMS_EXCLUDE=
TEAMMATE_TEAMS=
TEAM_SIZE_GUARD=25
DEFAULT_PRIORITY="direct team"
PRIORITY=$DEFAULT_PRIORITY

INCLUDE_DRAFTS=0
ALL_PRS=0
VERBOSE=0
CURRENT_USER=
CUTOFF_DATE=
ORGS_SCOPE=
SELECTED_TEAMS=
TEAMMATES=
RECORDS=
CHUNK=
CHUNK_KEYS=
CHUNK_COUNT=0
APPROVED_KEYS=
FLAG_ORGS=()
FLAG_TEAMS=()

# GitHub search rejects queries longer than 256 characters.
QUERY_LIMIT=256

SEARCH_JQ='(["__META__", (.total_count|tostring), (.incomplete_results|tostring), (.items|length|tostring)] | @tsv), (.items[] | [(.repository_url | split("/") | .[-2] + "/" + .[-1]), (.number|tostring), .created_at, (((now - (.created_at|fromdateiso8601)) / 86400) | floor | tostring), .user.login, (.title | gsub("[\r\n\t]"; " ")), .html_url] | @tsv)'

usage() {
  cat <<'EOF'
Usage: gh pr-queue [options]

Options:
  --drafts          Include draft pull requests
  --all             Disable the default created-date cutoff
  --verbose         Include age, author, and title details
  --org ORG         Limit to an organization; repeatable
  --team ORG/TEAM   Limit to a team slug and include teammate-authored PRs; repeatable
  --config PATH     Source an alternate config file
  -h, --help        Show this help

Config: ~/.config/gh-pr-queue/config
  CUTOFF_DAYS=14
  ORGS=
  TEAMS_INCLUDE=
  TEAMS_EXCLUDE=
  TEAMMATE_TEAMS=
  TEAM_SIZE_GUARD=25
  PRIORITY="direct team"
EOF
}

die() {
  printf 'gh-pr-queue: %s\n' "$*" >&2
  exit 1
}

warn() {
  printf 'gh-pr-queue: %s\n' "$*" >&2
}

line_has() {
  [ -n "$1" ] && printf '%s\n' "$1" | grep -Fxq "$2"
}

append_line() {
  if [ -n "$1" ]; then
    printf '%s\n%s' "$1" "$2"
  else
    printf '%s' "$2"
  fi
}

append_unique_line() {
  if line_has "$1" "$2"; then
    printf '%s' "$1"
  else
    append_line "$1" "$2"
  fi
}

csv_has() {
  local list=$1 item=$2 old_ifs=$IFS part
  [ -n "$list" ] || return 1
  IFS=,
  for part in $list; do
    part=${part// /}
    if [ "$part" = "$item" ]; then
      IFS=$old_ifs
      return 0
    fi
  done
  IFS=$old_ifs
  return 1
}

csv_to_lines() {
  local list=$1 old_ifs=$IFS part out=
  IFS=,
  for part in $list; do
    part=${part// /}
    [ -n "$part" ] || continue
    out=$(append_unique_line "$out" "$part")
  done
  IFS=$old_ifs
  printf '%s' "$out"
}

join_csv() {
  local out= item
  for item in "$@"; do
    if [ -n "$out" ]; then
      out="${out},${item}"
    else
      out=$item
    fi
  done
  printf '%s' "$out"
}

preparse_config_path() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --config)
        [ "$#" -ge 2 ] || die "--config requires a path"
        CONFIG_PATH=$2
        shift
        ;;
      --config=*)
        CONFIG_PATH=${1#*=}
        ;;
    esac
    shift
  done
}

parse_args() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --drafts)
        INCLUDE_DRAFTS=1
        ;;
      --all)
        ALL_PRS=1
        ;;
      --verbose)
        VERBOSE=1
        ;;
      --org)
        [ "$#" -ge 2 ] || die "--org requires an organization"
        FLAG_ORGS[${#FLAG_ORGS[@]}]=$2
        shift
        ;;
      --org=*)
        FLAG_ORGS[${#FLAG_ORGS[@]}]=${1#*=}
        ;;
      --team)
        [ "$#" -ge 2 ] || die "--team requires ORG/TEAM"
        FLAG_TEAMS[${#FLAG_TEAMS[@]}]=$2
        shift
        ;;
      --team=*)
        FLAG_TEAMS[${#FLAG_TEAMS[@]}]=${1#*=}
        ;;
      --config)
        shift
        ;;
      --config=*)
        ;;
      --self-check)
        run_self_check
        exit 0
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
    shift
  done

  if [ "${#FLAG_ORGS[@]}" -gt 0 ]; then
    ORGS=$(join_csv "${FLAG_ORGS[@]}")
  fi
  if [ "${#FLAG_TEAMS[@]}" -gt 0 ]; then
    TEAMS_INCLUDE=$(join_csv "${FLAG_TEAMS[@]}")
  fi
  if [ -n "$TEAMMATE_TEAMS" ] && [ "$PRIORITY" = "$DEFAULT_PRIORITY" ]; then
    PRIORITY="direct teammate team"
  elif [ -n "$TEAMS_INCLUDE" ] && [ "$PRIORITY" = "$DEFAULT_PRIORITY" ]; then
    PRIORITY="direct+teammate team"
  fi
}

validate_config() {
  case "$CUTOFF_DAYS" in
    ''|*[!0-9]*) die "CUTOFF_DAYS must be a non-negative integer" ;;
  esac
  case "$TEAM_SIZE_GUARD" in
    ''|*[!0-9]*) die "TEAM_SIZE_GUARD must be a non-negative integer" ;;
  esac

  local tokens=${PRIORITY//+/ } token
  for token in $tokens; do
    case "$token" in
      direct|teammate|team) ;;
      *) die "unknown PRIORITY token: $token" ;;
    esac
  done
}

priority_wants() {
  local tokens=${PRIORITY//+/ }
  case " $tokens " in
    *" $1 "*) return 0 ;;
    *) return 1 ;;
  esac
}

source_in_tier() {
  local tier=${1//+/ } source=$2 token
  for token in $tier; do
    [ "$token" = "$source" ] && return 0
  done
  return 1
}

load_user() {
  local line
  line=$(gh api user --jq '.login + "\t" + ((now - ('"$CUTOFF_DAYS"' * 86400)) | strftime("%Y-%m-%d"))')
  CURRENT_USER=${line%%$'\t'*}
  CUTOFF_DATE=${line#*$'\t'}
}

load_teams() {
  local lines org slug count team_id
  lines=$(gh api --paginate user/teams --jq '.[] | [.organization.login, .slug, ((.members_count // 0) | tostring)] | @tsv')

  while IFS=$'\t' read -r org slug count; do
    [ -n "${org:-}" ] || continue
    team_id="${org}/${slug}"

    if [ -n "$ORGS" ] && ! csv_has "$ORGS" "$org"; then
      continue
    fi
    if [ -n "$TEAMS_INCLUDE" ] && ! csv_has "$TEAMS_INCLUDE" "$team_id"; then
      continue
    fi
    if [ -n "$TEAMS_EXCLUDE" ] && csv_has "$TEAMS_EXCLUDE" "$team_id"; then
      continue
    fi

    SELECTED_TEAMS=$(append_line "$SELECTED_TEAMS" "${org}"$'\t'"${slug}"$'\t'"${count}")
    ORGS_SCOPE=$(append_unique_line "$ORGS_SCOPE" "$org")
  done <<EOF
$lines
EOF

  if [ -n "$ORGS" ]; then
    ORGS_SCOPE=$(csv_to_lines "$ORGS")
  fi
}

load_teammates() {
  local org slug count members member matched= team_id

  while IFS=$'\t' read -r org slug count; do
    [ -n "${org:-}" ] || continue
    if [ -n "$TEAMMATE_TEAMS" ] && ! csv_has "$TEAMMATE_TEAMS" "${org}/${slug}"; then
      continue
    fi
    matched=$(append_unique_line "$matched" "${org}/${slug}")
    if [ "$count" -gt "$TEAM_SIZE_GUARD" ]; then
      warn "skipping teammate expansion for ${org}/${slug} (${count} members > guard ${TEAM_SIZE_GUARD}); team review requests still count. Raise TEAM_SIZE_GUARD or narrow TEAMS_INCLUDE to include it."
      continue
    fi

    members=$(gh api --paginate "orgs/${org}/teams/${slug}/members" --jq '.[].login')
    while IFS= read -r member; do
      [ -n "$member" ] || continue
      [ "$member" = "$CURRENT_USER" ] && continue
      TEAMMATES=$(append_unique_line "$TEAMMATES" "$member")
    done <<EOF
$members
EOF
  done <<EOF
$SELECTED_TEAMS
EOF

  if [ -n "$TEAMMATE_TEAMS" ]; then
    while IFS= read -r team_id; do
      [ -n "$team_id" ] || continue
      line_has "$matched" "$team_id" || warn "TEAMMATE_TEAMS team not found among your teams: ${team_id}"
    done <<EOF
$(csv_to_lines "$TEAMMATE_TEAMS")
EOF
  fi
}

draft_part() {
  [ "$INCLUDE_DRAFTS" -eq 1 ] || printf ' draft:false'
}

cutoff_part() {
  [ "$ALL_PRS" -eq 1 ] || printf ' created:>=%s' "$CUTOFF_DATE"
}

base_query() {
  printf 'is:pr state:open%s%s' "$(draft_part)" "$(cutoff_part)"
}

record_pr() {
  local source=$1 repo=$2 number=$3 created=$4 age=$5 author=$6 title=$7 url=$8
  [ "$author" != "$CURRENT_USER" ] || return 0
  if [ "$source" = "teammate" ] && ! line_has "$TEAMMATES" "$author"; then
    return 0
  fi
  RECORDS=$(append_line "$RECORDS" "${source}"$'\t'"${repo}"$'\t'"${number}"$'\t'"${created}"$'\t'"${age}"$'\t'"${author}"$'\t'"${title}"$'\t'"${url}")
}

flush_review_chunk() {
  local out alias state idx key
  [ -n "$CHUNK" ] || return 0
  out=$(gh api graphql -f query="query {${CHUNK} }" --jq '.data | to_entries[] | [.key, (.value.pullRequest.reviews.nodes[0].state // "-")] | @tsv')
  while IFS=$'\t' read -r alias state; do
    [ -n "${alias:-}" ] || continue
    [ "$state" = "APPROVED" ] || continue
    idx=${alias#q}
    key=$(printf '%s\n' "$CHUNK_KEYS" | sed -n "$((idx + 1))p")
    [ -n "$key" ] || continue
    APPROVED_KEYS=$(append_unique_line "$APPROVED_KEYS" "$key")
  done <<EOF
$out
EOF
  CHUNK=
  CHUNK_KEYS=
  CHUNK_COUNT=0
}

# One aliased GraphQL query per 50 unique PRs replaces a REST reviews call
# per search hit; reviews(last: 1, author, states) yields the latest
# APPROVED/CHANGES_REQUESTED review by the current user regardless of how
# many reviews the PR has.
filter_approved() {
  [ -n "$RECORDS" ] || return 0
  local keys= source repo number created age author title url key owner name filtered=

  while IFS=$'\t' read -r source repo number created age author title url; do
    [ -n "${source:-}" ] || continue
    keys=$(append_unique_line "$keys" "${repo}#${number}")
  done <<EOF
$RECORDS
EOF

  CHUNK=
  CHUNK_KEYS=
  CHUNK_COUNT=0
  APPROVED_KEYS=
  while IFS= read -r key; do
    [ -n "$key" ] || continue
    repo=${key%"#"*}
    number=${key##*"#"}
    owner=${repo%%/*}
    name=${repo#*/}
    CHUNK="${CHUNK} q${CHUNK_COUNT}: repository(owner: \"${owner}\", name: \"${name}\") { pullRequest(number: ${number}) { reviews(last: 1, author: \"${CURRENT_USER}\", states: [APPROVED, CHANGES_REQUESTED]) { nodes { state } } } }"
    CHUNK_KEYS=$(append_line "$CHUNK_KEYS" "$key")
    CHUNK_COUNT=$((CHUNK_COUNT + 1))
    [ "$CHUNK_COUNT" -lt 50 ] || flush_review_chunk
  done <<EOF
$keys
EOF
  flush_review_chunk

  while IFS=$'\t' read -r source repo number created age author title url; do
    [ -n "${source:-}" ] || continue
    line_has "$APPROVED_KEYS" "${repo}#${number}" && continue
    filtered=$(append_line "$filtered" "${source}"$'\t'"${repo}"$'\t'"${number}"$'\t'"${created}"$'\t'"${age}"$'\t'"${author}"$'\t'"${title}"$'\t'"${url}")
  done <<EOF
$RECORDS
EOF
  RECORDS=$filtered
}

run_search() {
  local source=$1 query=$2 page=1 output line tag total incomplete page_count
  local repo number created age author title url

  while [ "$page" -le 10 ]; do
    output=$(gh api --method GET search/issues -f q="$query" -F per_page=100 -F page="$page" --jq "$SEARCH_JQ")
    page_count=0

    while IFS= read -r line; do
      [ -n "$line" ] || continue
      case "$line" in
        "__META__"$'\t'*)
          IFS=$'\t' read -r tag total incomplete page_count <<EOF
$line
EOF
          if [ "$page" -eq 1 ]; then
            if [ "$incomplete" = "true" ]; then
              warn "GitHub returned incomplete search results for: $query"
            fi
            if [ "$total" -gt 1000 ]; then
              warn "GitHub caps search results at 1000 for: $query; use --org, a shorter CUTOFF_DAYS, or narrower team config."
            fi
          fi
          ;;
        *)
          IFS=$'\t' read -r repo number created age author title url <<EOF
$line
EOF
          [ -n "${repo:-}" ] || continue
          record_pr "$source" "$repo" "$number" "$created" "$age" "$author" "$title" "$url"
          ;;
      esac
    done <<EOF
$output
EOF

    [ "$page_count" -eq 100 ] || break
    page=$((page + 1))
  done
}

fetch_direct() {
  local org base
  base=$(base_query)
  if [ -n "$ORGS_SCOPE" ]; then
    while IFS= read -r org; do
      [ -n "$org" ] || continue
      run_search direct "${base} user-review-requested:@me org:${org}"
    done <<EOF
$ORGS_SCOPE
EOF
  else
    run_search direct "${base} user-review-requested:@me"
  fi
  return 0
}

fetch_team() {
  local org slug count base
  base=$(base_query)

  if [ -n "$TEAMS_INCLUDE" ] || [ -n "$TEAMS_EXCLUDE" ]; then
    while IFS=$'\t' read -r org slug count; do
      [ -n "${org:-}" ] || continue
      run_search team "${base} team-review-requested:${org}/${slug}"
    done <<EOF
$SELECTED_TEAMS
EOF
    return 0
  fi

  if [ -n "$ORGS_SCOPE" ]; then
    while IFS= read -r org; do
      [ -n "$org" ] || continue
      run_search team "${base} team-review-requested-user:@me org:${org}"
    done <<EOF
$ORGS_SCOPE
EOF
  else
    run_search team "${base} team-review-requested-user:@me"
  fi
  return 0
}

# Repeated author: qualifiers OR together, so each query matches only
# teammate-authored PRs instead of scanning every open PR in the org.
# Teammates are chunked to keep each query under QUERY_LIMIT.
fetch_teammate() {
  local org base prefix query member
  [ -n "$TEAMMATES" ] || return 0
  [ -n "$ORGS_SCOPE" ] || return 0

  base=$(base_query)
  while IFS= read -r org; do
    [ -n "$org" ] || continue
    prefix="${base} org:${org}"
    query=$prefix
    while IFS= read -r member; do
      [ -n "$member" ] || continue
      if [ $(( ${#query} + ${#member} + 8 )) -gt "$QUERY_LIMIT" ]; then
        run_search teammate "$query"
        query=$prefix
      fi
      query="${query} author:${member}"
    done <<EOF
$TEAMMATES
EOF
    [ "$query" = "$prefix" ] || run_search teammate "$query"
  done <<EOF
$ORGS_SCOPE
EOF
  return 0
}

fetch_records() {
  if priority_wants teammate && { [ -n "$TEAMMATE_TEAMS" ] || [ -n "$TEAMS_INCLUDE" ]; }; then
    load_teammates
  fi
  priority_wants direct && fetch_direct
  priority_wants team && fetch_team
  [ -n "$TEAMMATES" ] && fetch_teammate
  filter_approved
  return 0
}

label_tier() {
  local raw=${1//+/ } token out= label
  for token in $raw; do
    case "$token" in
      direct) label="direct requests" ;;
      teammate) label="teammate-authored" ;;
      team) label="team requests" ;;
      *) label=$token ;;
    esac
    if [ -n "$out" ]; then
      out="${out} + ${label}"
    else
      out=$label
    fi
  done
  printf '%s' "$out"
}

render_queue() {
  local total=0 seen= tier tier_label candidates record tier_has_rows body=
  local source repo number created age author title url key sorted display_repo suffix count_word url_width scan_seen row

  for tier in $PRIORITY; do
    tier_label=$(label_tier "$tier")
    candidates=

    while IFS=$'\t' read -r source repo number created age author title url; do
      [ -n "${source:-}" ] || continue
      source_in_tier "$tier" "$source" || continue
      key="${repo}#${number}"
      line_has "$seen" "$key" && continue
      candidates=$(append_line "$candidates" "${created}"$'\t'"${repo}"$'\t'"${number}"$'\t'"${age}"$'\t'"${author}"$'\t'"${title}"$'\t'"${url}")
    done <<EOF
$RECORDS
EOF

    if [ -n "$candidates" ]; then
      if [ -n "$body" ]; then
        body+=$'\n\n'
      fi
      body+="$tier_label"
      tier_has_rows=0

      sorted=$(printf '%s\n' "$candidates" | sort)
      if [ "$VERBOSE" -eq 0 ]; then
        url_width=2
        scan_seen=$seen
        while IFS=$'\t' read -r created repo number age author title url; do
          [ -n "${repo:-}" ] || continue
          key="${repo}#${number}"
          line_has "$scan_seen" "$key" && continue
          [ "${#url}" -gt "$url_width" ] && url_width=${#url}
          scan_seen=$(append_unique_line "$scan_seen" "$key")
        done <<EOF
$sorted
EOF
        printf -v row '  %-*s  %s' "$url_width" "PR" "AUTHOR"
        body+=$'\n'"$row"
      fi

      while IFS=$'\t' read -r created repo number age author title url; do
        [ -n "${repo:-}" ] || continue
        key="${repo}#${number}"
        line_has "$seen" "$key" && continue
        seen=$(append_unique_line "$seen" "$key")
        display_repo=${repo#*/}
        if [ "$tier_has_rows" -eq 1 ] && [ "$VERBOSE" -eq 1 ]; then
          body+=$'\n'
        fi
        if [ "$VERBOSE" -eq 1 ]; then
          body+=$'\n'"  ${display_repo}#${number}  ${age}d  ${author}"
          body+=$'\n'"    ${title}"
        else
          printf -v row '  %-*s  @%s' "$url_width" "$url" "$author"
          body+=$'\n'"$row"
        fi
        tier_has_rows=1
        total=$((total + 1))
      done <<EOF
$sorted
EOF
    fi
  done

  if [ "$total" -eq 0 ]; then
    printf 'No PRs in queue.\n'
    return 0
  fi

  suffix=
  [ "$ALL_PRS" -eq 1 ] || suffix=" (${CUTOFF_DAYS}d cutoff)"
  count_word=PRs
  [ "$total" -eq 1 ] && count_word=PR
  printf '%s %s need review%s\n\n%s\n' "$total" "$count_word" "$suffix" "$body"
}

run_self_check() {
  CURRENT_USER=me
  PRIORITY="direct+teammate team"
  RECORDS=$'team\tacme/api\t9\t2026-01-04T00:00:00Z\t3\tpat\tTeam only\thttps://example.invalid/9\nteammate\tacme/api\t7\t2026-01-02T00:00:00Z\t5\tlee\t[DO NOT MERGE] Older\thttps://example.invalid/7\ndirect\tacme/app\t8\t2026-01-03T00:00:00Z\t4\tlee\tDirect newer\thttps://example.invalid/8\nteam\tacme/api\t7\t2026-01-02T00:00:00Z\t5\tlee\tDuplicate lower tier\thttps://example.invalid/7'

  local out order dupes
  out=$(render_queue)
  printf '%s\n' "$out" | grep -Fq 'PR                         AUTHOR' || die "self-check failed: compact output missing table header"
  printf '%s\n' "$out" | grep -Eq 'https://example.invalid/7 +@lee' || die "self-check failed: compact output missing PR link + author"
  ! printf '%s\n' "$out" | grep -Fq '[DO NOT MERGE] Older' || die "self-check failed: compact output included title"

  VERBOSE=1
  out=$(render_queue)
  printf '%s\n' "$out" | grep -Fq 'direct requests + teammate-authored' || die "self-check failed: missing merged tier"
  printf '%s\n' "$out" | grep -Fq '[DO NOT MERGE] Older' || die "self-check failed: missing title annotation"
  dupes=$(printf '%s\n' "$out" | grep -Fc '#7')
  [ "$dupes" -eq 1 ] || die "self-check failed: duplicate PR was not removed"
  order=$(printf '%s\n' "$out" | grep -E '#(7|8|9)' | sed 's/.*#\([0-9][0-9]*\).*/\1/' | tr '\n' ' ')
  [ "$order" = "7 8 9 " ] || die "self-check failed: expected oldest-first tier order, got: $order"
  VERBOSE=0

  RECORDS=
  record_pr direct acme/app 42 2026-01-01T00:00:00Z 6 lee "Approved" https://example.invalid/42
  record_pr direct acme/app 43 2026-01-01T00:00:00Z 6 lee "Needs review" https://example.invalid/43
  record_pr team acme/app 42 2026-01-01T00:00:00Z 6 lee "Approved dupe" https://example.invalid/42
  GH_CALL_LOG=$(mktemp)
  gh() {
    printf '.' >>"$GH_CALL_LOG"
    printf 'q0\tAPPROVED\nq1\t-\n'
  }
  filter_approved
  unset -f gh
  [ "$(wc -c <"$GH_CALL_LOG")" -eq 1 ] || die "self-check failed: expected one batched review query"
  rm -f "$GH_CALL_LOG"
  printf '%s\n' "$RECORDS" | grep -Fq $'\t43\t' || die "self-check failed: unapproved PR was not kept"
  ! printf '%s\n' "$RECORDS" | grep -Fq $'\t42\t' || die "self-check failed: approved PR was not filtered from all tiers"

  TEAMMATES=$'ann\nbob'
  ORGS_SCOPE=acme
  ALL_PRS=1
  INCLUDE_DRAFTS=1
  QUERIES=
  run_search() { QUERIES=$(append_line "$QUERIES" "$2"); }
  fetch_teammate
  [ "$(printf '%s\n' "$QUERIES" | grep -c .)" -eq 1 ] || die "self-check failed: short teammate list should be one query"
  printf '%s\n' "$QUERIES" | grep -Fq 'org:acme author:ann author:bob' || die "self-check failed: teammate query missing author qualifiers"

  TEAMMATES=
  local i=0
  while [ "$i" -lt 40 ]; do
    TEAMMATES=$(append_line "$TEAMMATES" "member-$(printf '%02d' "$i")")
    i=$((i + 1))
  done
  QUERIES=
  fetch_teammate
  [ "$(printf '%s\n' "$QUERIES" | grep -c .)" -gt 1 ] || die "self-check failed: long teammate list was not chunked"
  [ -z "$(printf '%s\n' "$QUERIES" | awk -v limit="$QUERY_LIMIT" 'length > limit')" ] || die "self-check failed: teammate query exceeds QUERY_LIMIT"
  printf 'self-check ok\n'
}

main() {
  preparse_config_path "$@"
  if [ -f "$CONFIG_PATH" ]; then
    # The config file is intentionally shell syntax: KEY=VALUE.
    # shellcheck source=/dev/null
    . "$CONFIG_PATH"
  fi
  parse_args "$@"
  validate_config
  load_user
  load_teams
  fetch_records
  render_queue
}

main "$@"
